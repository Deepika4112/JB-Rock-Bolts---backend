APP_NAME=JB Rock Bolts API
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=False
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# Option A — Railway MySQL (recommended for free deployment)
# Copy the DATABASE_URL value from Railway's MySQL service Variables tab here:
MYSQL_URL=mysql://user:password@host.railway.app:port/railway

# Option B — Individual vars (used when MYSQL_URL is not set)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jbrockbolts_db
DB_USER=root
DB_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your Vercel frontend URL here (comma-separated)
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173,http://localhost:8080

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-strong-random-secret-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Pagination ────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200

# ── Cloudflare R2 (File Storage) ──────────────────────────────────────────────
# Get these from Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=jb-rock-bolts
# Either the R2.dev public URL or your custom domain
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev
