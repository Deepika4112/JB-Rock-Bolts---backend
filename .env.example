APP_NAME=JB Rock Bolts API
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True
PORT=8000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jbrockbolts_db
DB_USER=root
DB_PASSWORD=

# CORS - comma-separated origins
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:8081,http://127.0.0.1:8080,http://127.0.0.1:8081,http://localhost:5173,http://127.0.0.1:5173

# Security
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200
